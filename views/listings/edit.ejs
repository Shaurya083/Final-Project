<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-2">
  <h3>Edit your List</h3>
  <form method="POST" action="/listings/<%=listing._id%>?_method=PUT">
     <div class="mb-3">
      <label for="title" class="form-lebel">Title</label>
      <input name="listing[title]" value="<%=listing.title%>" type="text" class="form-control">
     </div>
   <div class="mb-3">
    <label for="desciption" class="form-lebel">Description</label>
       <textarea name="listing[description]" value="<%=listing.desription%>" type="text" class="form-control"></textarea>
     </div>
 <div class="mb-3">
    <label for="image" class="form-lebel">Image Link</label>
     <input name="listing[image]" value="<%=listing.image%>" type="text" class="form-control">
     </div>
     <div class="row">
<div class="mb-3 col-md-4">
    <label for="price" class="form-lebel">Price</label>
   <input name="listing[price]" value="<%=listing.price%>" type="number" class="form-control">
     </div>
     <div class="mb-3 col-md-8">
       <label for="country" class="form-lebel">Country</label>
 <input name="listing[country]" value="<%=listing.country%>" type="text" class="form-control">
     </div>
     </div>

  
   <div class="mb-3">
    <label for="location" class="form-lebel">Location</label>
  <input name="listing[location]" value="<%=listing.location%>" type="text" class="form-control">
     </div>

  
  <button class="btn btn-dark add-btn">Edit</button>
  </form>
</div>
</div>