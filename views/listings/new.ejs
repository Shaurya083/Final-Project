<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-2">
    <br>
  <h3>Create A new List</h3>
  <form method="POST" action="/listings">
    <div class="mb-3">
<label for="title" class="form-lebel">Title</label>
  <input name="title" placeholder="Enter title" type="text" class="form-control">
    </div>
    <div class="mb-3">
      <label for="desciption" class="form-lebel">Description</label>
 <textarea name="description" placeholder="Enter description" type="text" class="form-control"></textarea>
    </div>
<div class="mb-3">
   <label for="image" class="form-lebel">Image Link</label>
 <input name="image" placeholder="Enter image URL/LINK" type="text" class="form-control">
</div>
<div class="row">
<div class="mb-3 col-md-4">
  <label for="price" class="form-lebel">Price</label>
<input name="price" placeholder="Enter price" type="number" class="form-control">
</div>
<div class="mb-3 col-md-8">
  <label for="country" class="form-lebel">Country</label>
 <input name="country" placeholder="Enter country" type="text" class="form-control">
</div>
</div>
<div>
  <label for="location" class="form-lebel">Location</label>
<input name="location" placeholder="Enter location" type="text" class="form-control">
</div>
  <br>
  <button class="btn btn-dark add-btn ">Add</button>
  <br><br>
  </form>
  </div>
  </div>